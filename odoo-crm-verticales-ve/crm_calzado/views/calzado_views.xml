<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_calzado_marca_tree" model="ir.ui.view">
        <field name="name">calzado.marca.tree</field>
        <field name="model">calzado.marca</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="pais_origen"/>
                <field name="segmento"/>
            </list>
        </field>
    </record>

    <record id="action_calzado_marca" model="ir.actions.act_window">
        <field name="name">Marcas</field>
        <field name="res_model">calzado.marca</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_calzado_modelo_tree" model="ir.ui.view">
        <field name="name">calzado.modelo.tree</field>
        <field name="model">calzado.modelo</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="marca_id"/>
                <field name="sku"/>
                <field name="categoria"/>
                <field name="genero"/>
                <field name="precio_usd"/>
            </list>
        </field>
    </record>

    <record id="view_calzado_modelo_kanban" model="ir.ui.view">
        <field name="name">calzado.modelo.kanban</field>
        <field name="model">calzado.modelo</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="marca_id"/>
                <field name="precio_usd"/>
                <field name="imagen"/>
                <templates>
                    <t t-name="card">
                        <div class="o_kanban_image">
                            <img t-att-src="kanban_image('calzado.modelo', 'imagen', record.id.raw_value)"
                                 alt="Modelo"/>
                        </div>
                        <div class="oe_kanban_details">
                            <strong><field name="name"/></strong>
                            <div><field name="marca_id"/></div>
                            <div>USD <field name="precio_usd"/></div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="action_calzado_modelo" model="ir.actions.act_window">
        <field name="name">Catálogo de Modelos</field>
        <field name="res_model">calzado.modelo</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_calzado_root"
              name="Calzado"
              parent="crm.crm_menu_root"
              sequence="30"/>
    <menuitem id="menu_calzado_marca"
              name="Marcas"
              parent="menu_calzado_root"
              action="action_calzado_marca"/>
    <menuitem id="menu_calzado_modelo"
              name="Catálogo de Modelos"
              parent="menu_calzado_root"
              action="action_calzado_modelo"/>
</odoo>
