<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="crm_lead_view_form_funeraria" model="ir.ui.view">
        <field name="name">crm.lead.form.funeraria</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Servicio Funerario" invisible="not is_funeraria">
                    <group>
                        <group string="Modalidad">
                            <field name="is_funeraria"/>
                            <field name="funeraria_modalidad"/>
                            <field name="funeraria_servicio_tipo"/>
                            <field name="urgencia"/>
                            <field name="plan_id"/>
                        </group>
                        <group string="Familiar Responsable">
                            <field name="familiar_responsable"/>
                            <field name="familiar_parentesco"/>
                            <field name="familiar_telefono"/>
                        </group>
                    </group>
                    <group string="Datos del Fallecido" invisible="funeraria_modalidad != 'necesidad'">
                        <group>
                            <field name="fallecido_nombre"/>
                            <field name="fallecido_cedula"/>
                            <field name="fallecido_fecha_nacimiento"/>
                        </group>
                        <group>
                            <field name="fallecido_fecha_fallecimiento"/>
                            <field name="fallecido_lugar"/>
                            <field name="fallecido_causa"/>
                        </group>
                    </group>
                    <group string="Servicio">
                        <group>
                            <field name="cementerio_id"/>
                            <field name="velatorio_sala"/>
                            <field name="velatorio_fecha"/>
                            <field name="sepelio_fecha"/>
                        </group>
                        <group string="Documentación">
                            <field name="acta_defuncion"/>
                            <field name="permiso_inhumacion"/>
                            <field name="permiso_cremacion"/>
                        </group>
                    </group>
                </page>
            </xpath>
            <xpath expr="//field[@name='priority']" position="before">
                <field name="is_funeraria"/>
            </xpath>
        </field>
    </record>
</odoo>
