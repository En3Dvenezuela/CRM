<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_autopartes_vehiculo_tree" model="ir.ui.view">
        <field name="name">autopartes.vehiculo.tree</field>
        <field name="model">autopartes.vehiculo</field>
        <field name="arch" type="xml">
            <list>
                <field name="display_name"/>
                <field name="partner_id"/>
                <field name="vin"/>
                <field name="placa"/>
                <field name="kilometraje"/>
            </list>
        </field>
    </record>

    <record id="view_autopartes_vehiculo_form" model="ir.ui.view">
        <field name="name">autopartes.vehiculo.form</field>
        <field name="model">autopartes.vehiculo</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="marca"/>
                            <field name="modelo"/>
                            <field name="version"/>
                            <field name="anio"/>
                            <field name="color"/>
                        </group>
                        <group>
                            <field name="vin"/>
                            <field name="placa"/>
                            <field name="motor"/>
                            <field name="transmision"/>
                            <field name="combustible"/>
                            <field name="kilometraje"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_autopartes_vehiculo" model="ir.actions.act_window">
        <field name="name">Vehículos</field>
        <field name="res_model">autopartes.vehiculo</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_autopartes_pieza_tree" model="ir.ui.view">
        <field name="name">autopartes.pieza.tree</field>
        <field name="model">autopartes.pieza</field>
        <field name="arch" type="xml">
            <list>
                <field name="codigo_interno"/>
                <field name="codigo_oem"/>
                <field name="name"/>
                <field name="categoria"/>
                <field name="origen"/>
                <field name="precio_venta_usd"/>
                <field name="stock_actual"/>
            </list>
        </field>
    </record>

    <record id="action_autopartes_pieza" model="ir.actions.act_window">
        <field name="name">Catálogo de Piezas</field>
        <field name="res_model">autopartes.pieza</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_autopartes_root"
              name="Autopartes"
              parent="crm.crm_menu_root"
              sequence="25"/>
    <menuitem id="menu_autopartes_vehiculo"
              name="Vehículos"
              parent="menu_autopartes_root"
              action="action_autopartes_vehiculo"/>
    <menuitem id="menu_autopartes_pieza"
              name="Catálogo de Piezas"
              parent="menu_autopartes_root"
              action="action_autopartes_pieza"/>
</odoo>
